{
  "name": "zeitungsjunge",
  "version": "1.0.0",
  "description": "Smart headline aggregator - AI, Tech, E-Commerce news from top sources",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "scrape": "node src/cli.js",
    "scrape:today": "node src/cli.js --range today",
    "scrape:week": "node src/cli.js --range week",
    "scrape:month": "node src/cli.js --range month",
    "scrape:all": "node src/cli.js --range all",
    "build-html": "node src/build-html.js"
  },
  "keywords": [
    "news",
    "aggregator",
    "headlines",
    "ai",
    "tech",
    "ecommerce",
    "scraping"
  ],
  "author": "Elisabeth Schallerl",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.7",
    "cheerio": "^1.0.0-rc.12",
    "rss-parser": "^3.13.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  }
}
